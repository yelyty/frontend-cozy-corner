---
import Layout from "../layouts/BlogPost.astro";
import Divider from "../components/Divider.astro";
import profilePhoto from "../assets/me.jpeg";
---

<Layout
  title="About me"
  description="Learn more about me, the author of this blog."
  showTitle={false}
  showDate={false}
>
  <div class="profile">
    <div class="profile-photo-frame">
      <img
        class="profile-photo"
        src={profilePhoto.src}
        alt="Portrait of Liza"
      />
    </div>

    <p>
      Hi, I am Liza, a frontend developer with over 6 years of experience in the
      industry. When I'm not coding, you can find me hiking in the mountains,
      reading literature, or exploring new places.
    </p>
  </div>
  <section class="timeline-section">
    <p class="section-label">Things I've professionally worked on</p>

    <div class="timeline">
      <article class="stop">
        <span class="dot"></span>
        <div class="when">Where it started</div>
        <h3>A social app for sport clubs</h3>
        <p>
          A social network for sport clubs and events that shipped on web. I
          built the social feed and a personal profile with an achievements &
          results dashboard.
        </p>
      </article>

      <article class="stop">
        <span class="dot"></span>
        <div class="when">Then</div>
        <h3>To the railways</h3>
        <p>
          A custom service-center platform for the railway industry, where
          manufacturers and their customers share one system to track equipment,
          schedule service, and file warranty claims.
        </p>
      </article>

      <article class="stop">
        <span class="dot"></span>
        <div class="when">Across time zones</div>
        <h3>Senior care</h3>
        <p>
          An American startup connecting senior-care providers with families.
          It's also where I got to stretch the most, building across a handful
          of very different screens.
        </p>
      </article>
    </div>
  </section>
  <Divider />
  <div class="social-links-wrapper">
    <p class="social-title">See also</p>
    <div class="social-links">
      <a href="https://github.com/yelyty" target="_blank" rel="noopener">
        <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/lizatymoshenko"
        target="_blank"
        rel="noopener"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          width="16"
          height="16"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.852 3.37-1.852 3.601 0 4.267 2.37 4.267 5.455v6.288zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
        LinkedIn
      </a>
    </div>
  </div>
  <style>
    .profile {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .profile-photo-frame {
      flex-shrink: 0;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      overflow: hidden;
    }
    .profile-photo {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .profile p {
      flex: 1;
      font-size: 16px;
      line-height: 1.75;
      color: rgba(var(--text-primary), 0.85);
      margin: 0;
    }
    .social-links-wrapper {
      display: flex;
      flex: 1;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }
    .social-title {
      margin-bottom: 0.5rem;
    }
    .social-links {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .social-links a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 18px;
      border-radius: 999px;
      background: var(--bg-primary);
      border: 1px solid rgba(var(--text-primary), 0.15);
      color: rgb(var(--text-primary));
      text-decoration: none;
      font-size: 14px;
      transition: all 0.25s ease;
    }

    .social-links a svg {
      width: 16px;
      height: 16px;
      color: var(--accent);
      transition: color 0.25s ease;
    }

    .social-links a:hover {
      background: var(--secondary);
      border-color: var(--accent);
      color: var(--accent-dark);
      transform: translateY(-2px);
    }

    .social-links a:hover svg {
      color: var(--accent-dark);
    }

    .social-links a:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    .section-label {
      font-style: italic;
      font-size: 18px;
      color: var(--accent);
      margin-bottom: 1.5rem;
      padding-left: 2px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-label::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--accent);
    }

    .timeline {
      position: relative;
      padding-left: 34px;
    }

    .timeline::before {
      content: "";
      position: absolute;
      left: 8px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background: var(--accent);
    }

    .stop {
      position: relative;
      margin-bottom: 2.2rem;
    }

    .stop:last-child {
      margin-bottom: 0;
    }

    .dot {
      position: absolute;
      left: -36px;
      top: 4px;
      width: 15px;
      height: 15px;
      border-radius: 50%;
      background: var(--accent);
      border: 4px solid var(--bg-primary);
      box-shadow: 0 0 0 1px rgba(var(--text-primary), 0.12);
    }

    .when {
      font-size: 12.5px;
      color: rgba(var(--text-primary), 0.55);
      letter-spacing: 0.03em;
      margin-bottom: 3px;
    }

    .stop h3 {
      font-weight: 500;
      font-size: 19px;
      color: rgb(var(--text-primary));
      margin-bottom: 6px;
      line-height: 1.3;
    }

    .stop h3 a {
      color: var(--accent-dark);
      text-decoration: none;
      border-bottom: 1.5px solid var(--secondary);
      transition: border-color 0.2s ease;
    }

    .stop h3 a:hover {
      border-color: var(--accent);
    }

    .stop > p {
      font-size: 15px;
      color: var(--text-primary);
      margin-bottom: 12px;
      line-height: 1.7;
    }
  </style>
</Layout>
