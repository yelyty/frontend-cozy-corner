---
import ArrowRight from "phosphor-astro/ArrowRightBold.astro";
import Layout from "../layouts/BlogPost.astro";
import Divider from "../components/Divider.astro";
import profilePhoto from "../assets/me.jpeg";
import SocialLinks from "../components/SocialLinks.astro";
import Tag from "../components/Tag.astro";
---

<Layout
  title="About me"
  description="Learn more about me, the author of this blog."
  showTitle={false}
  showDate={false}
  goBack={false}
>
  <div class="profile">
    <div class="profile-photo-frame">
      <img
        class="profile-photo"
        src={profilePhoto.src}
        alt="Portrait of Liza"
      />
    </div>

    <p>
      Hi, I am Liza, a frontend developer with over 6 years of experience in the
      industry. When I'm not coding, you can find me hiking in the mountains,
      reading literature, or exploring new places.
    </p>
  </div>
  <section class="timeline-section">
    <p class="section-label">Things I've professionally worked on</p>

    <div class="timeline">
      <article class="stop">
        <span class="dot"></span>
        <div class="when">Where it started</div>
        <h3>A social app for sport clubs</h3>
        <p>
          Web application that helps users to find and join different sport
          events in the city, to meet like-minded people for sport activities,
          with a built-in attendance system for event organizers.
        </p>
        <ul class="achievements-list">
          <li>Built the social feed</li>
          <li>Blog UI for articles</li>
          <li>
            Built a personal profile with an achievements & results dashboard
          </li>
          <li>Maintained existing features</li>
        </ul>
        <div>
          <Tag size="large">React</Tag>
          <Tag size="large">JavaScript</Tag>
          <Tag size="large">Sass</Tag>
          <Tag size="large">Bootstrap</Tag>
          <Tag size="large">Redux</Tag>
          <Tag size="large">Apollo</Tag>
          <Tag size="large">GraphQL</Tag>
        </div>
      </article>

      <article class="stop">
        <span class="dot"></span>
        <div class="when">Then</div>
        <h3>To the railways</h3>
        <p>
          Green-field project. A custom service-center platform for the railway
          industry, where manufacturers and their customers share one system to
          track equipment, schedule service, and file warranty claims.
        </p>
        <ul class="achievements-list">
          <li>Front-end setup</li>
          <li>Build a lot of tables and long forms</li>
          <li>And, of course, dashboards</li>
        </ul>
        <a
          class="project-link"
          href="https://astrumq.com/jak-jsme-vyvijeli-webovy-system-a-design-aplikace-pro-lokomotivy-cz-loko/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Read the case study <ArrowRight width="16" />
        </a>
        <div>
          <Tag size="large">React</Tag>
          <Tag size="large">JavaScript</Tag>
          <Tag size="large">Redux</Tag>
          <Tag size="large">And definetely something else I forgot</Tag>
        </div>
      </article>

      <article class="stop">
        <span class="dot"></span>
        <div class="when">Across time zones</div>
        <h3>Senior care</h3>
        <p>
          An American startup connecting senior-care providers with families.
          The whole projects consists of a few clients, and I personally worked
          on the following:
        </p>
        <p>Web application with messaging and administration feature.</p>
        <p>Mobile app for messaging</p>
        <p>Digital Signage app for Android TV</p>
        <p>Supporting app for digital signage</p>
        <div>
          <Tag size="large">NextJs</Tag>
          <Tag size="large">Tailwind</Tag>
          <Tag size="large">React</Tag>
          <Tag size="large">React Native</Tag>
          <Tag size="large">TypeScript</Tag>
          <Tag size="large">MUI</Tag>
          <Tag size="large">Urql</Tag>
          <Tag size="large">Storybook</Tag>
        </div>
      </article>
    </div>
  </section>
  <Divider />
  <div class="social-links-wrapper">
    <p class="social-title">See also</p>
    <SocialLinks />
  </div>
  <style>
    .project-link {
      display: inline-block;
      margin-bottom: 2rem;
    }
    .profile {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .profile-photo-frame {
      flex-shrink: 0;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      overflow: hidden;
    }
    .profile-photo {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .profile p {
      flex: 1;
      line-height: 1.75;
      margin: 0;
    }

    @media (max-width: 520px) {
      .profile {
        flex-direction: column;
      }
    }
    .social-links-wrapper {
      display: flex;
      flex: 1;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }
    .social-title {
      margin-top: 0;
      margin-bottom: 0.5rem;
    }
    .timeline {
      position: relative;
      padding-left: 34px;
    }
    .section-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 20px;
    }

    .section-label::after {
      content: "";
      flex: 1;
      border-bottom: 1px solid var(--accent);
    }

    .timeline::before {
      content: "";
      position: absolute;
      left: 8px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background: var(--accent);
    }

    .stop {
      position: relative;
      margin-bottom: 2.2rem;
    }

    .stop:last-child {
      margin-bottom: 0;
    }

    .dot {
      position: absolute;
      left: -36px;
      top: 4px;
      width: 15px;
      height: 15px;
      border-radius: 50%;
      background: var(--accent);
      border: 4px solid var(--bg-primary);
      box-shadow: 0 0 0 1px rgba(var(--text-primary), 0.12);
    }

    .when {
      font-size: 12px;
      color: rgba(var(--text-primary), 0.55);
      letter-spacing: 0.14em;
      margin-bottom: 3px;
      text-transform: uppercase;
    }

    .stop h3 {
      font-weight: 500;
      font-size: 20px;
      color: rgb(var(--text-primary));
      margin-bottom: 6px;
      line-height: 1.3;
    }

    .stop h3 a {
      color: var(--accent-dark);
      text-decoration: none;
      border-bottom: 1.5px solid var(--secondary);
      transition: border-color 0.2s ease;
    }

    .stop h3 a:hover {
      border-color: var(--accent);
    }

    .stop > p {
      color: var(--text-primary);
      margin-bottom: 12px;
      line-height: 1.7;
    }

    .timeline li {
      list-style: none;
      padding: 0;
      margin: 0;

      position: relative;
      padding-left: 24px;
      margin-bottom: 12px;
      line-height: 1.55;
    }

    .timeline li::before {
      content: "\25C6";
      position: absolute;
      left: 0;
      top: 3px;
      color: var(--accent);
      font-size: 0.7em;
    }

    .achievements-list {
      padding-left: 0;
    }
  </style>
</Layout>
