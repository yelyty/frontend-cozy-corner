---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import logo from "../assets/logo.svg";
import logodark from "../assets/logodark.svg";
---

<header>
  <nav>
    <a href="/" class="logo-link">
      <img src={logo.src} alt={SITE_TITLE} class="logo logo-light" />
      <img src={logodark.src} alt={SITE_TITLE} class="logo logo-dark" />
    </a>

    <button
      class="burger"
      id="burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="internal-link drawer" id="nav-menu">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <ThemeToggle/>
    </div>
  </nav>
  <script type="module" is:inline>
    // Burger menu
    const burger = document.getElementById("burger");
    const navMenu = document.getElementById("nav-menu");
    burger?.addEventListener("click", () => {
      const expanded = burger.getAttribute("aria-expanded") === "true";
      burger.setAttribute("aria-expanded", String(!expanded));
      navMenu?.classList.toggle("open");
      burger.classList.toggle("open");
    });
  </script>
</header>
<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: var(--bg-primary);
  }
  .logo-link {
    display: flex;
    align-items: center;
	flex:1;
    text-decoration: none;
  }
  .logo {
    height: 70px;
    width: auto;
    display: block;
  }
  .logo-dark {
    display: none;
  }
  @media (prefers-color-scheme: dark) {
    .logo-light {
      display: none;
    }
    .logo-dark {
      display: block;
    }
  }
  [data-theme="dark"] .logo-light {
    display: none;
  }
  [data-theme="dark"] .logo-dark {
    display: block;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    padding-left: 30px;
    padding-right: 30px;
	border-bottom-style: solid;
	border-bottom-color: var(--accent);
	border-bottom-width: 1px;
  }
  .internal-links {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1em;
    width: 100%;
    transition:
      max-height 0.3s ease,
      opacity 0.3s ease;
  }
  .internal-link {
	display: flex;
	align-items: center;
  }
  .drawer {
    transition:
      transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s;
  }
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;b
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1001;
    margin-left: 1em;
  }
  .burger span {
    display: block;
    width: 28px;
    height: 3px;
    margin: 4px 0;
    background: var(--accent);
    border-radius: 2px;
    transition: 0.3s;
  }
  .burger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger.open span:nth-child(2) {
    opacity: 0;
  }
  .burger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  nav a {
    padding: 1em 0.5em;
    color: rgb(var(--text-primary));
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
	color: var(--accent)
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 900px) {
    nav {
      padding-left: 10px;
      padding-right: 10px;
    }
    .burger {
      display: flex;
    }
    .drawer {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      width: 100vw;
      max-width: 400px;
      background: var(--bg-primary);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transform: translateX(100%);
      opacity: 0;
      pointer-events: none;
      box-shadow: -2px 0 16px rgba(0, 0, 0, 0.15);
      z-index: 2000;
      gap: 2em;
      padding-top: 80px;
      padding-bottom: 2em;
    }
    .drawer.open {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
    }
    .drawer a {
      padding: 1em 2em;
      width: 100%;
      display: block;
      font-size: 1.2em;
      text-align: center;
    }
    body {
      overflow-x: hidden;
    }
  }
  body {
    margin: 0;
    overflow-x: hidden;
  }
</style>
