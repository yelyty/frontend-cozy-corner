---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Tag from '../components/Tag.astro';
import Divider from '../components/Divider.astro';

type Props = Partial<CollectionEntry<'blog'>['data']> & {
	title: string;
	description: string;
	showTitle?: boolean;
	showDate?: boolean;
	tag: string;
};

const {
	title,
	description,
	pubDate,
	showTitle = true,
	showDate = true,
	tag,
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			html, body {
				height: 100%;
				margin: 0;
			}

			body {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}

			main {
				flex: 1 0 auto;
				display: flex;
				flex-direction: column;
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				margin-top: 111px;	
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--text-primary));
				text-align: justify;
			}
			.title {
				padding: 1rem 0;
				line-height: 1;
				font-size: 3rem;
			}
			.date {
				color: rgb(var(--text-primary));
				opacity: 0.7;
				font-size: 1rem;
			}
			footer {
				flex-shrink: 0;
				margin-top: auto;
			}
			.data {
				display: flex;
				flex-direction: row;
				justify-content: flex-start;
				align-items: center;
				gap: 10px;
			}
			.all-posts {
				display: block;
				text-decoration: none;
				font-size: 1rem;
				margin-bottom: 20px;
			}

			.all-posts:hover {
				text-decoration: underline;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<a href="/blog" class="all-posts">&larr; All posts</a>
					<div class="data">
						<Tag>{tag}</Tag>
						{showDate && pubDate && (
								<div class="date">
									<FormattedDate date={pubDate} />
								</div>
							)}
					</div>
					{showTitle && (
						
							<h1 class="title">{title}</h1>
							<Divider />
					
					)}
					<slot />
							<Divider />
				</div>
				
			</article>
		</main>
		<Footer />
	</body>
</html>
