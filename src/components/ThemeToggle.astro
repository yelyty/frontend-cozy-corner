</button>

<script is:inline>
  (function () {
    const btn = document.getElementById("theme-toggle");
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");

    function setTheme(theme) {
      document.documentElement.setAttribute("data-theme", theme);
      try {
        localStorage.setItem("theme", theme);
      } catch (e) {}
      if (btn) btn.setAttribute("aria-checked", String(theme === "dark"));
    }

    const saved = localStorage.getItem("theme");
    if (saved) setTheme(saved);
    else setTheme(prefersDark.matches ? "dark" : "light");

    btn?.addEventListener("click", () => {
      const current = document.documentElement.getAttribute("data-theme");
      setTheme(current === "dark" ? "light" : "dark");
      btn.classList.remove("tg-squish");
      void btn.offsetWidth;
      btn.classList.add("tg-squish");
    });

    prefersDark.addEventListener("change", (e) => {
      if (!localStorage.getItem("theme"))
        setTheme(e.matches ? "dark" : "light");
    });
  })();
</script>

<style>
  @keyframes tg-twinkle {
    0%,
    100% {
      opacity: 0.25;
      transform: scale(0.8);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }
  @keyframes tg-drift {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(var(--tg-drift));
    }
  }
  @keyframes tg-squish {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(0.94);
    }
    100% {
      transform: scale(1);
    }
  }

  .theme-toggle {
    --tg-w: 100px;
    --tg-h: 45px;
    --tg-inset: calc(var(--tg-h) * 0.094);
    --tg-knob: calc(var(--tg-h) - var(--tg-inset) * 2);
    --tg-slide: calc(var(--tg-w) - var(--tg-knob) - var(--tg-inset) * 2);
    --tg-drift: calc(var(--tg-w) * 0.095);

    position: relative;
    width: var(--tg-w);
    height: var(--tg-h);
    border-radius: calc(var(--tg-h) / 2);
    border: none;
    cursor: pointer;
    padding: 0;
    overflow: hidden;
    background: #f6dcae;
    box-shadow: inset 0 2px 5px rgba(160, 120, 60, 0.18);
    transition: background 0.8s ease;
	margin-left: 30px;
  }
  .theme-toggle.tg-squish {
    animation: tg-squish 0.26s ease;
  }
  .theme-toggle:focus-visible {
    outline: 2px solid #c98a6a;
    outline-offset: 3px;
  }

  .tg-cloud {
    position: absolute;
    line-height: 0;
    transition: opacity 0.6s ease;
  }
  .tg-cloud svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .tg-cloud-1 {
    top: 18%;
    left: 48%;
    width: 26%;
    height: 26%;
    animation: tg-drift 3s ease-in-out infinite alternate;
  }
  .tg-cloud-2 {
    top: 50%;
    left: 62%;
    width: 20%;
    height: 20%;
    animation: tg-drift 3.6s ease-in-out infinite alternate 0.5s;
  }

  .tg-star {
    position: absolute;
    border-radius: 50%;
    background: #ffe8b8;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .tg-star-1 {
    top: 25%;
    left: 12%;
    width: 4px;
    height: 4px;
    animation: tg-twinkle 2s ease-in-out infinite;
  }
  .tg-star-2 {
    top: 60%;
    left: 20%;
    width: 3px;
    height: 3px;
    animation: tg-twinkle 2.4s ease-in-out infinite 0.6s;
  }
  .tg-star-3 {
    top: 38%;
    left: 30%;
    width: 3px;
    height: 3px;
    animation: tg-twinkle 1.8s ease-in-out infinite 1.1s;
  }

  .tg-knob {
    position: absolute;
    top: var(--tg-inset);
    left: var(--tg-inset);
    width: var(--tg-knob);
    height: var(--tg-knob);
    transition: transform 0.7s cubic-bezier(0.34, 1.45, 0.5, 1);
    pointer-events: none;
    z-index: 2;
  }
  .tg-rays line {
    transform-origin: 24px 24px;
    transition:
      transform 0.6s cubic-bezier(0.34, 1.4, 0.64, 1),
      opacity 0.5s;
  }
  .tg-orb {
    transition: fill 0.8s ease;
  }
  .tg-crater {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .tg-sun-face {
    transition: opacity 0.4s ease;
  }
  .tg-moon-face {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  :global([data-theme="dark"]) .theme-toggle {
    background: #3a302a;
  }
  :global([data-theme="dark"]) .tg-knob {
    transform: translateX(var(--tg-slide)) rotate(330deg);
  }
  :global([data-theme="dark"]) .tg-orb {
    fill: #f0d9a8;
  }
  :global([data-theme="dark"]) .tg-rays line {
    transform: scale(0);
    opacity: 0;
  }
  :global([data-theme="dark"]) .tg-crater {
    opacity: 1;
  }
  :global([data-theme="dark"]) .tg-sun-face {
    opacity: 0;
  }
  :global([data-theme="dark"]) .tg-moon-face {
    opacity: 1;
  }
  :global([data-theme="dark"]) .tg-cloud {
    opacity: 0;
  }
  :global([data-theme="dark"]) .tg-star {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle,
    .tg-knob,
    .tg-orb,
    .tg-rays line,
    .tg-crater,
    .tg-sun-face,
    .tg-moon-face,
    .tg-cloud,
    .tg-star {
      transition: none;
    }
    .theme-toggle.tg-squish {
      animation: none;
    }
    .tg-cloud,
    .tg-star {
      animation: none;
    }
  }
</style>
