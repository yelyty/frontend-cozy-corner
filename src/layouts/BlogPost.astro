---
import type { CollectionEntry } from 'astro:content';
import ArrowLeft from "phosphor-astro/ArrowLeftBold.astro";
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Tag from '../components/Tag.astro';
import Divider from '../components/Divider.astro';
import PlantsWithGooglyEyes from '../components/PlantsWithGooglyEyes.astro';
import ShareButtons from "../components/ShareButtons.astro";

type Props = Partial<CollectionEntry<'blog'>['data']> & {
	title: string;
	description: string;
	showTitle?: boolean;
	showDate?: boolean;
	tag?: string;
	goBack?: boolean;
};

const {
	title,
	description,
	pubDate,
	showTitle = true,
	showDate = true,
	tag,
	goBack = true,
} = Astro.props;

const url = new URL(Astro.url.pathname, Astro.site).href;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			html, body {
				height: 100%;
				margin: 0;
			}

			body {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}

			main {
				flex: 1 0 auto;
				display: flex;
				flex-direction: column;
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				margin-top: 111px;	
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--text-primary));
				text-align: justify;
			}

		 .prose :global(li)::marker {
    color: var(--accent);
  }
			.title {
				padding: 1rem 0;
				line-height: 1;
				font-size: 3rem;
				text-align: center;
			}
			 @media (max-width: 520px) {

    .title {
      font-size: 30px;
    }

  }
.prose :global(a) {
    color: var(--accent);
    text-decoration: none;
    background: linear-gradient(var(--accent), var(--accent)) no-repeat 0 100% / 0% 1.5px;
    transition: background-size 0.3s ease;
    padding-bottom: 2px;
  }
  .prose :global(a:hover) {
    background-size: 100% 1.5px;
  }
  .prose :global(a:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

			.date {
				color: rgb(var(--text-primary));
				opacity: 0.7;
				font-size: 1rem;
			}
			footer {
				flex-shrink: 0;
				margin-top: auto;
			}
			.data {
				display: flex;
				flex-direction: row;
				justify-content: flex-start;
				align-items: center;
				gap: 10px;
			}
			.all-posts {
				display: flex;
				align-items: center;
				text-decoration: none;
				font-size: 1rem;
				margin-bottom: 20px;
				gap: 0.5rem;
			}

			.all-posts:hover {
				text-decoration: underline;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					{goBack && <a href="/blog" class="all-posts"><ArrowLeft width="16px"/> All posts</a>}
					<div class="data">
						{tag && <Tag>{tag}</Tag>}
						{showDate && pubDate && (
								<div class="date">
									<FormattedDate date={pubDate} />
								</div>
							)}
					</div>
					{showTitle && (
						
							<h1 class="title">{title}</h1>
							<Divider />
					
					)}
					<slot />
							<Divider />
							<ShareButtons title={title} url={url} />
				</div>
				
			</article>
		</main>
		<PlantsWithGooglyEyes />
		<Footer />
	</body>
</html>
