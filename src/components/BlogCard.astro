---
import FormattedDate from "./FormattedDate.astro";

interface Props {
  url: string;
  postedDate: Date;
  title: string;
  tag?: string;
  description?: string;
}

const { url, postedDate, title, tag, description } = Astro.props;
---

<a class="post-card" href={url}>
  <div class="post-meta">
    <span class="post-date"><FormattedDate date={postedDate} /></span>
    {tag && <span class="post-tag">{tag}</span>}
  </div>
  <h3 class="post-card-title">{title}</h3>
  {description && <p class="post-excerpt">{description}</p>}
</a>

<style>
  .post-card {
    display: block;
    border: 1px solid rgba(var(--text-primary), 0.08);
    border-radius: 14px;
    padding: 1.1rem 1.3rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
  }

  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(var(--text-primary), 0.08);
  }

  .post-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 5px;
  }

  .post-date {
    font-size: 12px;
    color: rgba(var(--text-primary), 0.55);
  }

  .post-tag {
    font-size: 11px;
    padding: 2px 9px;
    border-radius: 999px;
    border-width: 0.5px;
    border-style: solid;
    border-color: var(--accent-dark);
    color: var(--accent-dark);
  }

  .post-card-title {
    font-size: 19px;
    font-weight: 500;
    color: rgb(var(--text-primary));
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .post-excerpt {
    font-size: 14px;
    color: rgba(var(--text-primary), 0.7);
    margin: 0 0 8px;
    line-height: 1.55;
  }
</style>
