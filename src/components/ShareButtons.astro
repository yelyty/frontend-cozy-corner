---
import ShareFat from "phosphor-astro/ShareFatBold.astro";
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const u = encodeURIComponent(url);
const t = encodeURIComponent(title);

const links = [
  {
    name: "LinkedIn",
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${u}`,
    path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.852 3.37-1.852 3.601 0 4.267 2.37 4.267 5.455v6.288zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
  {
    name: "Reddit",
    href: `https://www.reddit.com/submit?url=${u}&title=${t}`,
    path: "M12 0C5.373 0 0 5.373 0 12c0 6.627 5.373 12 12 12s12-5.373 12-12C24 5.373 18.627 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 01-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 01.042.52c0 2.694-3.13 4.87-6.993 4.87-3.863 0-6.993-2.176-6.993-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 014.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 01.14-.197.35.35 0 01.238-.042l2.906.617a1.214 1.214 0 011.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 00-.231.094.33.33 0 000 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 00.029-.463.33.33 0 00-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 00-.232-.095z",
  },
  {
    name: "Bluesky",
    href: `https://bsky.app/intent/compose?text=${t}%20${u}`,
    path: "M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.789.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z",
  },
  {
    name: "Email",
    href: `mailto:?subject=${t}&body=${u}`,
    path: "M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67zM22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z",
  },
];
---

<p class="share-title">Share <ShareFat width="16" /></p>
<div class="share-links">
  {
    links.map((l) => (
      <a href={l.href} target="_blank" rel="noopener noreferrer">
        <svg
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          width="16"
          height="16"
        >
          <path d={l.path} />
        </svg>
        {l.name}
      </a>
    ))
  }
  <button id="copy-link" data-url={url} type="button">
    <svg
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      width="16"
      height="16"
    >
      <path
        d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"
      ></path>
    </svg>
    <span id="copy-label">Copy link</span>
  </button>
</div>

<script>
  document.getElementById("copy-link")?.addEventListener("click", async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(btn.dataset.url!);
    const label = btn.querySelector("#copy-label");
    if (!label) return;
    const prev = label.textContent;
    label.textContent = "Copied!";
    setTimeout(() => (label.textContent = prev), 1500);
  });
</script>

<style>
  .share-title {
    text-align: center;
    align-items: center;
  }
  .share-links {
    display: flex;
    justify-content: center;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    text-align: center;
  }

  .share-links a,
  .share-links button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border-radius: 999px;
    background: var(--bg-primary);
    border: 1px solid rgba(var(--text-primary), 0.15);
    color: rgb(var(--text-primary));
    text-decoration: none;
    font-size: 14px;
    font-family: inherit;
    line-height: 1;
    box-sizing: border-box;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .share-links a svg,
  .share-links button svg {
    width: 16px;
    height: 16px;
    color: var(--accent);
    transition: color 0.25s ease;
  }

  .share-links a:hover,
  .share-links button:hover {
    background: var(--secondary);
    border-color: var(--accent);
    color: var(--accent-dark);
    transform: translateY(-2px);
  }

  .share-links a:hover svg,
  .share-links button:hover svg {
    color: var(--accent-dark);
  }

  .share-links a:focus-visible,
  .share-links button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
</style>
