---
interface Props {
  cite?: string;
}

const { cite } = Astro.props;
---

<blockquote class="quote" cite={cite}>
  <slot />
</blockquote>

<style>
  .quote {
    margin: 2rem 0;
    padding: 0 0 0 20px;
    border-left: 3px solid var(--secondary);
    border-radius: 0;
    font-family: var(--font-serif, "Fraunces", serif);
    font-style: italic;
    font-size: 22px;
    line-height: 1.5;
    color: var(--accent-dark);
  }

  .quote :global(p) {
    margin: 0;
  }

  .quote :global(p + p) {
    margin-top: 0.6em;
  }

  @media (max-width: 520px) {
    .quote {
      font-size: 19px;
      padding-left: 16px;
    }
  }
</style>
